# Environment Variables
# Copy this file to .env and fill in the values

# Arbitrum RPC URL for deployment (required)
STYLUS_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Private key for deployment (required) [secret]
DEPLOYER_PRIVATE_KEY=

# Deployed ERC1155 multi-token address
NEXT_PUBLIC_ERC1155_ADDRESS=

# Private key for deployment and transactions (required) [secret]
PRIVATE_KEY=

# URL of the ERC1155 deployment API
ERC1155_DEPLOYMENT_API_URL=http://localhost:4002

# WalletConnect Cloud project ID for wallet connections (required)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Application name displayed in wallet dialogs
NEXT_PUBLIC_APP_NAME=My DApp

# Chainlink Data Feed contract address (AggregatorV3Interface) (required)
CHAINLINK_FEED_ADDRESS=0x639Fe6ab55C921f74e7fac1ee960C0B6293ba612

# Chain for Chainlink feed (e.g. ARBITRUM or ARBITRUM_SEPOLIA) (required)
CHAINLINK_CHAIN=ARBITRUM

# Alchemy API key for RPC access (required)
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Dune Analytics API key for blockchain data queries (required) [secret]
DUNE_API_KEY=